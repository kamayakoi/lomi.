{
  "name": "@lomi./mcp",
  "version": "0.1.0",
  "private": true,
  "description": "Model Context Protocol server for the lomi. merchant REST API",
  "type": "module",
  "bin": {
    "lomi-mcp": "./dist/index.js",
    "lomi-mcp-http": "./dist/http-entry.js"
  },
  "scripts": {
    "build": "tsc",
    "generate": "tsx scripts/generate-tools.ts",
    "generate:check": "pnpm run generate && git diff --exit-code src/generated/",
    "prebuild": "pnpm run generate",
    "start": "node dist/index.js",
    "start:http": "node dist/http-entry.js",
    "dev": "tsx src/index.ts",
    "dev:http": "LOMI_MCP_TRANSPORT=http tsx src/http-entry.ts",
    "test": "vitest run",
    "smoke:http": "tsx scripts/smoke-http.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^5.2.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.19.19",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  },
  "keywords": [
    "lomi.",
    "mcp",
    "model-context-protocol",
    "payments"
  ],
  "license": "AGPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/lomiafrica/lomi./",
    "directory": "apps/mcp"
  }
}
