{
  "name": "docs",
  "version": "0.0.1",
  "private": true,
  "pnpm": {
    "overrides": {
      "fast-xml-parser": "^5.3.4",
      "@isaacs/brace-expansion": "^5.0.1",
      "undici": "^5.28.4",
      "lodash": "^4.17.21"
    }
  },
  "scripts": {
    "build": "pnpm build:pre && NODE_OPTIONS='--max-old-space-size=8192' next build && pnpm build:post",
    "build:pre": "bun ./lib/scripts/pre-build.ts",
    "build:post": "bun ./lib/scripts/post-build.ts",
    "clean": "rimraf .next",
    "dev": "NODE_OPTIONS='--max-old-space-size=8192' next dev --turbo",
    "lint": "fumadocs-mdx && bun ./lib/scripts/lint.ts && eslint .",
    "knip": "knip",
    "start": "next start",
    "mdx": "pnpm exec fumadocs-mdx",
    "format": "prettier --write .",
    "map": "tsx --env-file=.env lib/scripts/core/generate_sitemap.ts"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^1.0.30",
    "@fumadocs/mdx-remote": "^1.4.4",
    "@mixedbread/sdk": "^0.27.0",
    "@orama/core": "^1.2.19",
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.90.1",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "ai": "^5.0.119",
    "critters": "^0.0.25",
    "fumadocs-core": "~16.2.5",
    "fumadocs-docgen": "^3.0.5",
    "fumadocs-mdx": "^14.2.4",
    "fumadocs-openapi": "^10.2.4",
    "fumadocs-twoslash": "^3.1.12",
    "fumadocs-typescript": "^4.0.14",
    "fumadocs-ui": "~16.2.5",
    "katex": "^0.16.27",
    "lucide-react": "^0.542.0",
    "mermaid": "^11.12.2",
    "next": "^16.1.6",
    "next-sanity": "^11.6.12",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "remark": "^15.0.1",
    "remark-mdx": "^3.1.1",
    "rimraf": "^6.1.2",
    "sanity": "^4.22.0",
    "styled-components": "^6.3.3",
    "unist-util-visit": "^5.0.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.2",
    "@next/env": "^16.1.1",
    "@next/eslint-plugin-next": "^16.1.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/mdx": "^2.0.13",
    "@types/node": "24.3.1",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.52.0",
    "@typescript-eslint/parser": "^8.52.0",
    "algoliasearch": "5.37.0",
    "eslint": "^9.39.2",
    "eslint-config-custom": "^0.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.5.0",
    "gray-matter": "^4.0.3",
    "knip": "5.63.0",
    "next-validate-link": "^1.6.4",
    "postcss": "^8.5.6",
    "prettier": "^3.7.4",
    "tailwindcss": "^4.1.18",
    "tailwindcss-animate": "^1.0.7",
    "tinyglobby": "^0.2.15",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "browserslist": [
    "defaults",
    "not IE 11"
  ]
}
