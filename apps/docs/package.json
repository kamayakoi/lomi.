{
  "name": "docs",
  "version": "0.0.1",
  "private": true,
  "pnpm": {
    "overrides": {
      "fast-xml-parser": "^5.3.4",
      "@isaacs/brace-expansion": "^5.0.1",
      "undici": "^5.28.4",
      "lodash": "^4.17.21",
      "postcss": "^8.5.15",
      "vite": "^7.3.2",
      "yaml": "^2.8.3"
    }
  },
  "scripts": {
    "build": "pnpm build:pre && NODE_OPTIONS='--max-old-space-size=8192' next build && pnpm build:post",
    "build:pre": "bun ./lib/scripts/pre-build.ts",
    "build:pre:sync": "DOCS_SYNC_OPENAPI=1 bun ./lib/scripts/pre-build.ts",
    "build:post": "bun ./lib/scripts/post-build.ts",
    "clean": "rimraf .next",
    "dev": "NODE_OPTIONS='--max-old-space-size=8192' next dev --turbo",
    "lint": "fumadocs-mdx && bun ./lib/scripts/lint.ts && bun ./lib/scripts/check-mdx-sdk-snippets.ts && pnpm exec tsx lib/scripts/manual-api/verify-en-operation-overrides.ts && eslint .",
    "api:bootstrap": "pnpm exec tsx lib/scripts/bootstrap-manual-api-reference.ts",
    "api:regenerate-rest-reference": "pnpm exec tsx lib/scripts/bootstrap-manual-api-reference.ts",
    "knip": "knip",
    "start": "next start",
    "mdx": "pnpm exec fumadocs-mdx",
    "format": "prettier --write .",
    "map": "tsx --env-file=.env lib/scripts/core/generate_sitemap.ts",
    "test:tryit": "bun test lib/openapi-secure-proxy.allowlist.test.ts"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.48",
    "@mixedbread/sdk": "^0.27.0",
    "@orama/core": "^1.2.19",
    "@oramacloud/client": "^2.1.4",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.2.6",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.106.2",
    "@tailwindcss/container-queries": "^0.1.1",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "ai": "^6.0.195",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "critters": "^0.0.25",
    "d3-force": "^3.0.0",
    "fumadocs-core": "~16.8.12",
    "fumadocs-docgen": "^3.0.10",
    "fumadocs-mdx": "^14.3.2",
    "fumadocs-openapi": "^10.9.1",
    "fumadocs-twoslash": "^3.2.0",
    "fumadocs-typescript": "^4.0.14",
    "fumadocs-ui": "~16.8.12",
    "katex": "^0.16.47",
    "lucide-react": "^0.542.0",
    "next": "^16.2.6",
    "next-themes": "^0.4.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-force-graph-2d": "^1.29.1",
    "rehype-katex": "^7.0.1",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-mdx": "^3.1.1",
    "rimraf": "^6.1.3",
    "shiki": "^4.1.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "unist-util-visit": "^5.1.0",
    "xmlbuilder2": "^4.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@next/env": "^16.2.6",
    "@next/eslint-plugin-next": "^16.2.6",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/d3-force": "^3.0.10",
    "@types/hast": "^3.0.4",
    "@types/mdx": "^2.0.13",
    "@types/node": "24.3.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "algoliasearch": "5.37.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.5.0",
    "gray-matter": "^4.0.3",
    "knip": "5.63.0",
    "next-validate-link": "^1.6.6",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.0",
    "tailwindcss-animate": "^1.0.7",
    "tinyglobby": "^0.2.16",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3"
  },
  "browserslist": [
    "defaults",
    "not IE 11"
  ]
}
