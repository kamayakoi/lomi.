{
  "name": "api",
  "version": "0.0.1",
  "description": "",
  "author": "Babacar Diop",
  "private": true,
  "license": "AGPL-3.0",
  "scripts": {
    "build:local": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "types": "pnpm run generate:api-types",
    "generate:modules": "pnpx tsx src/utils/scripts/generate-modules.ts",
    "generate:api-types": "pnpx tsx src/utils/scripts/generate-api-types.ts",
    "list:tables": "pnpx tsx src/utils/scripts/list-tables.ts",
    "fix:specs": "pnpx tsx src/utils/scripts/fix-specs.ts",
    "knip": "pnpm dlx knip",
    "openapi:export": "pnpx tsx src/scripts/export-openapi.ts"
  },
  "keywords": [
    "lomi",
    "payments",
    "mobile money",
    "orange money",
    "wave",
    "orange",
    "wave",
    "mtn",
    "cli",
    "api",
    "sdk",
    "nodejs",
    "typescript",
    "vite",
    "react",
    "react-native"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/lomiafrica/lomi./"
  },
  "pnpm": {
    "overrides": {
      "@isaacs/brace-expansion": "^5.0.1",
      "diff": "^5.2.0",
      "lodash": "4.17.23"
    }
  },
  "dependencies": {
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/swagger": "^11.4.1",
    "@nestjs/throttler": "^6.5.0",
    "@supabase/supabase-js": "^2.104.0",
    "axios": "^1.15.2",
    "bullmq": "^5.76.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "express": "^5.2.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "stripe": "^20.4.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.19.17",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^16.5.0",
    "jest": "^30.3.0",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s",
      "!**/*.spec.ts",
      "!**/*.module.ts",
      "!**/dto/**",
      "!main.ts",
      "!open-api-export.module.ts",
      "!swagger.config.ts",
      "!api-config.ts",
      "!**/scripts/**",
      "!utils/scripts/**",
      "!webhooks-open-api.module.ts",
      "!**/webhooks/providers/**",
      "!**/webhooks/listeners/**",
      "!**/webhooks/processors/**",
      "!**/webhooks/guards/**"
    ],
    "coverageDirectory": "../coverage",
    "coverageThreshold": {
      "global": {
        "branches": 18,
        "functions": 18,
        "lines": 22,
        "statements": 22
      }
    },
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1",
      "^@core/(.*)$": "<rootDir>/core/$1",
      "^@utils/(.*)$": "<rootDir>/utils/$1"
    }
  }
}
