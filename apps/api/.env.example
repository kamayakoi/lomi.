# Environment
NODE_ENV=development

# Security
CORS_ALLOWED_ORIGINS=https://lomi.africa, https://dashboard.lomi.africa, https://api.lomi.africa, https://portal.lomi.africa, https://pay.lomi.africa, https://store.lomi.africa, https://checkout.lomi.africa

# Redis (required in production for async usage metering + billing Bull queues)
# Without this, POST /usage-events still works but processes synchronously.
# UPSTASH_REDIS_URL=rediss://default:YOUR_TOKEN@your-db.upstash.io:6379

# ---------------------------------------------------------------------------
# Safe rollout feature flags (see api_runtime_config in Supabase for SQL flags)
# ---------------------------------------------------------------------------
# Merchant webhook outbox + BullMQ as single retry authority (per-org canary supported).
# WEBHOOK_OUTBOX_ENABLED=true
# WEBHOOK_OUTBOX_CANARY_ORG_IDS=uuid-one,uuid-two

# Node-side mirror for observability only; rate limits are enforced in SQL (verify_api_key).
# RATE_LIMIT_POLICY_RESOLVER_ENABLED=false