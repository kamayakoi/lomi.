# ---------------------------------------------------------------------------
# Core
# ---------------------------------------------------------------------------
NODE_ENV=development
# Set by Railway automatically in production (default local: 3000)
# PORT=3000

# ---------------------------------------------------------------------------
# Supabase (required)
# ---------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=your-service-role-key

# ---------------------------------------------------------------------------
# Redis / BullMQ (required in production)
# Async webhooks, usage metering, and billing queues. Without UPSTASH_REDIS_URL,
# the API falls back to synchronous processing where possible.
# ---------------------------------------------------------------------------
# UPSTASH_REDIS_URL=rediss://default:YOUR_TOKEN@your-db.upstash.io:6379

# Local dev only (when UPSTASH_REDIS_URL is unset)
# REDIS_HOST=localhost
# REDIS_PORT=6379

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=https://lomi.africa,https://dashboard.lomi.africa,https://api.lomi.africa,https://portal.lomi.africa,https://pay.lomi.africa,https://store.lomi.africa,https://checkout.lomi.africa


# ---------------------------------------------------------------------------
# Stripe (required for card payments)
# ---------------------------------------------------------------------------
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_SECRET_KEY_TEST=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_WEBHOOK_SECRET_TEST=whsec_...

# ---------------------------------------------------------------------------
# Wave (required for Wave webhooks)
# ---------------------------------------------------------------------------
# WAVE_WEBHOOK_SECRET=your-wave-webhook-secret

# ---------------------------------------------------------------------------
# Feature flags (see api_runtime_config in Supabase for SQL flags)
# ---------------------------------------------------------------------------
# CLI_LISTEN_ALLOW_PRODUCTION=true
# RATE_LIMIT_POLICY_RESOLVER_ENABLED=false
